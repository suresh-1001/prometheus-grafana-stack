# Grafana admin credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme   # !! CHANGE THIS !!

# MinIO credentials (used by Loki for log storage)
# Must match the values in config/loki.yml
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin   # !! CHANGE THIS !!
